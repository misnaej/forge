__pycache__/
*.pyc
*.pyo
*.swp
.DS_Store
.idea/
.vscode/
*.egg-info/
dist/
build/
node_modules/

# Session state — gitignored by foundation convention (see FOUNDATION.md §10)
.plan/

# Per-user Claude Code settings live in .claude/settings.local.json.
# Exceptions tracked in the repo so every contributor gets them on
# clone:
# - .claude/skills/ — forge-private project-local skills (e.g.
#   /promote — forge's dev→main release ceremony). Not exported via
#   the plugin manifest.
# - .claude/agents/ — forge-private project-local agent wrappers (e.g.
#   issue-triage-forge — adds the forge-internal label rule on top of
#   forge:issue-triage). Not exported via the plugin manifest.
# - .claude/settings.json — project-shared Claude Code config:
#   enables the forge plugin pinned to the dev channel so the
#   marketplace + plugin config is identical for every contributor.
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**

# Local scratch.
tmp/

# Pre-commit check logs (FOUNDATION §13).
code_health/

# Local issue exports for offline review (forge contributor workflow).
issue_*.md

# Per-clone conda env name (see .conda_env_name.example). Gitignored so each
# working copy can name its own env without touching tracked files.
.conda_env_name

# Per-clone forge git-hook version stamp (written by install-forge-githooks).
# Gitignored so refreshing the recorded version never dirties the tracked hooks.
.githooks/.forge-hook-version

# forge-gen-c4 on-demand offline HTML view (regenerate: forge-gen-c4 --format html)
docs/architecture.html
docs/mermaid.min.js
